digraph {
rankdir=TB;
node [shape=box];

Start [shape=ellipse];
End [shape=ellipse];

Start -> "Open Add Device" -> "Enter Device Data" -> "Validate Input" -> Decision;
Decision [shape=diamond label="Valid Input?"];

Decision -> "Save Device" [label="Yes"];
Decision -> "Show Error" [label="No"];

"Save Device" -> End;
"Show Error" -> "Retry Input" -> End;
}
