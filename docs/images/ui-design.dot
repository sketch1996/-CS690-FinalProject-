digraph {
  rankdir=LR;
  graph [fontsize=20, labelloc=t, label="UI Design - Console Screens"];
  node [shape=box, fontname="Arial"];

  "Main Menu" [label="Main Menu\n- Add Device\n- Search Device\n- Update Status\n- Assign Technician\n- Log Issue\n- Generate Report"];
  "Add Device Screen" [label="Add Device Screen\nEnter device details"];
  "Search Device Screen" [label="Search Device Screen\nEnter ID / Name / IP"];
  "Update Status Screen" [label="Update Status Screen\nSelect new status"];
  "Assign Technician Screen" [label="Assign Technician Screen\nSelect technician"];
  "Log Issue Screen" [label="Log Issue Screen\nEnter issue details"];
  "Report Screen" [label="Report Screen\nSelect criteria and view report"];

  "Main Menu" -> "Add Device Screen";
  "Main Menu" -> "Search Device Screen";
  "Main Menu" -> "Update Status Screen";
  "Main Menu" -> "Assign Technician Screen";
  "Main Menu" -> "Log Issue Screen";
  "Main Menu" -> "Report Screen";
}
