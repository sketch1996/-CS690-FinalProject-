digraph {
  rankdir=TB;
  graph [fontsize=20, labelloc=t, label="Architecture - 4 Layer Console Design"];
  node [shape=box, fontname="Arial"];

  UI [label="UI Layer\nConsole menus\nInput / Output"];
  Service [label="Service Layer\nBusiness logic\nValidation\nSearch / Update / Report"];
  Data [label="Data Layer\nFile read / write\nPersistence"];
  Model [label="Model Layer\nDevice\nIssue\nAssignment\nTechnician\nSystemGroup"];

  UI -> Service -> Data -> Model;
}
