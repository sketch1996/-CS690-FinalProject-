digraph {
  rankdir=TB;
  graph [fontsize=20, labelloc=t, label="Prototype - User Flow"];
  node [shape=box, fontname="Arial"];
  edge [fontname="Arial"];

  Start [shape=ellipse];
  End [shape=ellipse];
  D1 [shape=diamond, label="Device found?"];

  Start -> "Main Menu";
  "Main Menu" -> "Search Device";
  "Search Device" -> D1;
  D1 -> "View Device Details" [label="Yes"];
  D1 -> "Show Not Found Message" [label="No"];
  "Main Menu" -> "Add Device";
  "Add Device" -> "Save Confirmation";
  "Main Menu" -> "Assign Technician";
  "Assign Technician" -> "Assignment Saved";
  "Main Menu" -> "Generate Report";
  "Generate Report" -> "View Report Output";

  "View Device Details" -> End;
  "Show Not Found Message" -> End;
  "Save Confirmation" -> End;
  "Assignment Saved" -> End;
  "View Report Output" -> End;
}
